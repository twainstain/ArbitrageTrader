# ============================================================
# Arbitrage Trader — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env — it's in .gitignore.
# ============================================================

# --- Dashboard Auth (HTTP Basic) ---
DASHBOARD_USER=admin
DASHBOARD_PASS=adminTest

# --- Bot Defaults (override with CLI flags) ---
BOT_CONFIG=config/example_config.json
BOT_ITERATIONS=10
BOT_DRY_RUN=true
BOT_NO_SLEEP=false
BOT_MODE=simulated          # simulated | live | onchain | subgraph | historical

# --- RPC Endpoints (use Alchemy/Infura for production) ---
# Public endpoints are used by default but are rate-limited.
# RPC_ETHEREUM=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
# RPC_ARBITRUM=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
# RPC_BASE=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
# RPC_BSC=https://bsc-dataseed.binance.org

# --- The Graph (for subgraph market source) ---
# THEGRAPH_API_KEY=your_key_here

# --- Database ---
# Leave empty for SQLite (default: data/arbitrage.db)
# Set to Postgres URL for production (self-hosted container, see docker-compose.yml):
# DATABASE_URL=postgresql://arb:CHANGE_ME@postgres:5432/arbitrage

# --- Self-hosted Postgres (docker-compose service `postgres`) ---
# Generate a strong password:  openssl rand -base64 32
POSTGRES_DB=arbitrage
POSTGRES_USER=arb
# POSTGRES_PASSWORD=

# --- S3 backup (scripts/backup_postgres.sh) ---
# Prefer an IAM role on the EC2 instance over static keys.
S3_BACKUP_BUCKET=arb-trader-data
S3_BACKUP_PREFIX=postgres/evm/
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# --- On-Chain Execution (ONLY for live trading) ---
# EXECUTOR_PRIVATE_KEY=0x...
# EXECUTOR_CONTRACT=0x...

# --- Telegram Alerts ---
# 1. Message @BotFather on Telegram → create bot → get token
# 2. Start chat with bot → GET https://api.telegram.org/bot<TOKEN>/getUpdates → find chat_id
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# TELEGRAM_CHAT_ID=987654321

# --- Discord Alerts ---
# Channel Settings → Integrations → Webhooks → copy URL
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# --- Gmail Alerts ---
# 1. Enable 2FA on Google account
# 2. myaccount.google.com → Security → App passwords → generate for "Mail"
# GMAIL_ADDRESS=you@gmail.com
# GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
# GMAIL_RECIPIENT=you@gmail.com
